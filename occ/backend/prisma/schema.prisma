generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  CLUB_ADMIN
  PLATFORM_ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum ClubVisibility {
  PUBLIC
  PRIVATE
}

enum ClubApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostVisibility {
  PUBLIC
  CLUB
  MEMBERS_ONLY
}

enum ModerationStatus {
  PENDING
  PUBLISHED
  REJECTED
  REMOVED
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum GigApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(USER)
  status          UserStatus       @default(ACTIVE)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  profile         Profile?
  refreshTokens   RefreshToken[]
  clubsOwned      Club[]
  reviewedClubs   Club[]           @relation("ClubReviews")
  memberships     ClubMember[]
  joinRequests    ClubJoinRequest[]
  posts           Post[]
  comments        Comment[]
  likes           Like[]
  shares          Share[]
  reportsMade     Report[]         @relation("reportsMade")
  reviewedReports Report[]         @relation("reportsReviewed")
  settings        UserSetting?
  privacy         PrivacySetting?
  adminActionLogs AdminActionLog[]
  passwordResets  PasswordResetToken[]
  gigApplications GigApplication[]
  reviewedGigApplications GigApplication[] @relation("GigApplicationsReviewed")

  @@index([role])
  @@index([status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique  // SHA-256 hash of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  bio         String?
  university  String?
  phoneNumber String?
  hobbies     String?
  avatarUrl   String?
  coverUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  clubs     Club[]
}

model Club {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  description  String
  categoryId   String?
  university   String?
  locationName String?
  latitude     Float?
  longitude    Float?
  logoUrl      String?
  bannerUrl    String?
  isActive     Boolean        @default(true)
  approvalStatus ClubApprovalStatus @default(PENDING)
  isVerified   Boolean        @default(false) // legacy field kept dormant while club approval relies on approvalStatus only
  reviewedAt   DateTime?
  reviewedByAdminId String?
  rejectionReason String?
  visibility   ClubVisibility @default(PUBLIC)
  ownerId      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviewedByAdmin User?       @relation("ClubReviews", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  members      ClubMember[]
  joinRequests ClubJoinRequest[]
  posts        Post[]

  @@index([slug])
  @@index([university])
  @@index([approvalStatus, isActive])
}

model Gig {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  shortDescription String
  fullDescription  String
  category         String
  pricing          String?
  instructions     String?
  requirements     String?
  bannerUrl        String?
  isActive         Boolean          @default(true)
  isPublic         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  applications     GigApplication[]

  @@index([slug])
  @@index([category])
  @@index([isActive, isPublic])
}

model GigApplication {
  id                 String               @id @default(cuid())
  userId             String?
  gigId              String
  name               String
  email              String
  phone              String
  college            String
  reason             String
  relevantExperience String?
  status             GigApplicationStatus @default(PENDING)
  reviewedByAdminId  String?
  reviewedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  gig                Gig                  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  reviewedByAdmin    User?                @relation("GigApplicationsReviewed", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@unique([userId, gigId])
  @@index([gigId, status])
  @@index([userId, status])
  @@index([email, gigId])
}

model ClubMember {
  id             String         @id @default(cuid())
  clubId         String
  userId         String
  membershipRole MembershipRole @default(MEMBER)
  joinedAt       DateTime       @default(now())
  club           Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@index([clubId])
}

model ClubJoinRequest {
  id        String            @id @default(cuid())
  clubId    String
  userId    String
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  club      Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model Post {
  id               String           @id @default(cuid())
  authorId         String
  clubId           String?
  content          String
  imageUrl         String?
  visibility       PostVisibility   @default(PUBLIC)
  moderationStatus ModerationStatus @default(PUBLISHED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  club             Club?            @relation(fields: [clubId], references: [id], onDelete: SetNull)
  comments         Comment[]
  likes            Like[]
  shares           Share[]
  reports          Report[]

  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([authorId])
  @@index([clubId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Comment[] @relation("CommentReplies")

  @@index([postId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Share {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model Report {
  id                String       @id @default(cuid())
  postId            String
  reporterId        String
  reason            String
  description       String?
  status            ReportStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime     @default(now())
  post              Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter          User         @relation("reportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedByAdmin   User?        @relation("reportsReviewed", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([status])
}

model UserSetting {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  themePreference         String   @default("system")
  notificationPreferences Json     @default("{}")
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrivacySetting {
  id                  String            @id @default(cuid())
  userId              String            @unique
  profileVisibility   ProfileVisibility @default(PUBLIC)
  showUniversity      Boolean           @default(true)
  showClubMembership  Boolean           @default(true)
  postVisibilityDefault PostVisibility  @default(PUBLIC)
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  actionType String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}
